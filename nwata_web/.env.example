# Django Configuration for nwata_web

# REQUIRED: Generate a new SECRET_KEY for production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-long-random-secret-key-here-min-50-chars

# Set to False for production deployment
DEBUG=False

# Database URL (leave empty for SQLite, or set for PostgreSQL)
# Local SQLite (default): sqlite:///db.sqlite3
# PostgreSQL example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Production domain for CSRF origins
PROD_ORIGIN=https://yourdomain.com
